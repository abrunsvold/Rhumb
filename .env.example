# Rhumb environment — copy to .env and fill in. NEVER commit your real .env.
# Both hosts read from the environment; you can keep one shared file and export it
# for each. Only CLAUDE_CODE_OAUTH_TOKEN is strictly required to boot the agent host;
# each capability (infra, services) turns on only when its vars are present.

# ── Required: Claude subscription auth ───────────────────────────────────────
# From `claude setup-token` (your Claude subscription — NOT an API key).
CLAUDE_CODE_OAUTH_TOKEN=

# ── Control-plane security (strongly recommended) ────────────────────────────
# Shared operator secret. When set, driving the agent and approving gated infra
# actions require `Authorization: Bearer <token>`. Unset = control plane is open
# to anything on your tailnet. Generate with: openssl rand -hex 32
RHUMB_CONTROL_TOKEN=
# Comma-separated client origins allowed to reach the control plane (surface isolation).
# RHUMB_APP_ORIGINS=tauri://localhost

# ── Core ─────────────────────────────────────────────────────────────────────
# RHUMB_PORT=8787                     # agent host (default 8787)
# RHUMB_DASHBOARD_PORT=8788           # dashboard host (default 8788)
# RHUMB_MODEL=claude-opus-4-8
# RHUMB_PERMISSION_MODE=acceptEdits   # default | acceptEdits | bypassPermissions | plan
# Shared workspace (file-as-contract). Point BOTH hosts at the same path.
# Keep it OUTSIDE the repo — it holds data-sources.json (DB passwords), audit logs,
# the ontology vault, and spawned-service code. (Also gitignored as `workspace/`.)
RHUMB_WORKSPACE=./workspace

# ── Infrastructure capability (Proxmox VM/LXC + DB provisioning) ─────────────
# Set ALL FOUR proxmox vars + the PG admin string to enable infra tools.
# Use a SCOPED, least-privilege API token — needs VM.Allocate, VM.Config.*
# (incl. VM.Config.Network), VM.PowerMgmt, VM.Audit, Datastore.AllocateSpace/Audit,
# Sys.Audit, and (PVE 9) SDN.Use on the bridge zone.
# RHUMB_PROXMOX_URL=https://your-pve-host:8006
# RHUMB_PROXMOX_TOKEN_ID=rhumb@pve!rhumb
# RHUMB_PROXMOX_TOKEN_SECRET=
# RHUMB_PROXMOX_NODE=pve
# Postgres admin/superuser connection used to provision new databases.
# RHUMB_PG_ADMIN=postgres://postgres:CHANGEME@localhost:5432/postgres
# If your PVE uses a self-signed cert, the Proxmox client's TLS will reject it.
# Until a CA-cert option lands, set (scoped to the agent-host process):
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ── Spawned services (agent-built apps in their own LXC) ─────────────────────
# Deploy keypair: the PUBLIC key is injected into each spawned container; the
# PRIVATE key stays here (host-only). RHUMB_DEPLOY_PUBKEY defaults to <key>.pub.
# RHUMB_DEPLOY_KEY=/path/to/rhumb-deploy
# RHUMB_DEPLOY_PUBKEY=
# RHUMB_LXC_TEMPLATE=local:vztmpl/ubuntu-24.04-standard_24.04-2_amd64.tar.zst
# RHUMB_LXC_STORAGE=local-lvm
# RHUMB_LXC_BRIDGE=vmbr0
# RHUMB_LXC_ROOTFS_GB=8
# A fresh container can inherit an unusable PVE-injected resolver (e.g. Tailscale
# MagicDNS with no tailscaled in the container), which hangs apt/npm. Defaults to
# 1.1.1.1; override if your network needs a different resolver.
# RHUMB_LXC_NAMESERVER=1.1.1.1
# How long a redeployed service must hold healthy (stable probes, no restarts)
# before blue-green cutover. Milliseconds; default 90000.
# RHUMB_HEALTH_GATE_MS=90000

# ── Optional path overrides (all default under RHUMB_WORKSPACE) ───────────────
# RHUMB_DATA_SOURCES=<workspace>/data-sources.json
# RHUMB_DATA_TRUST=<workspace>/data-trust.json
# RHUMB_DATA_AUDIT=<workspace>/data-audit.jsonl
# RHUMB_INFRA_AUDIT=<workspace>/infra-audit.jsonl
# RHUMB_SERVICES=<workspace>/services.json
# RHUMB_ONTOLOGY=<workspace>/ontology
