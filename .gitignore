node_modules/
dist/
.DS_Store
.superpowers/

# Local secrets and config — never commit. Rhumb reads all credentials
# (CLAUDE_CODE_OAUTH_TOKEN, RHUMB_PROXMOX_*, RHUMB_PG_ADMIN, deploy keys) from
# the environment; keep them out of the repo.
.env
.env.*
!.env.example

# Agent workspace (default RHUMB_WORKSPACE=./workspace). Holds runtime data —
# data-sources.json (contains DB connection strings WITH passwords), the trust
# store, audit logs, the ontology vault, and spawned-service code. NEVER commit it.
workspace/

# Deploy keypairs, if generated in-tree.
*.pem
id_ed25519*
id_rsa*

# Scratch workspace created by agent-host's index.smoke.test.ts (relative ./ws default)
agent-host/ws/
